%%{init: {"theme":"base","themeVariables":{"primaryColor":"#ffffff","primaryBorderColor":"#455a64","lineColor":"#546e7a","fontFamily":"Arial","fontSize":"14px"},"flowchart":{"htmlLabels":true,"curve":"basis","nodeSpacing":52,"rankSpacing":68}}}%%
flowchart LR
        classDef actor fill:#eef6ff,stroke:#1e3a5f,stroke-width:1.5px,color:#102a43,font-weight:bold;
        classDef usecase fill:#ffffff,stroke:#455a64,stroke-width:1.2px,color:#102027;
        classDef automatic fill:#fff7e6,stroke:#8d6e63,stroke-width:1.2px,color:#3e2723;
        classDef legend fill:#f7f7f7,stroke:#9e9e9e,stroke-dasharray: 4 3,color:#212121;

        Aluno([Aluno]):::actor
        Professor([Professor]):::actor
        Parceiro([Empresa Parceira]):::actor
        Sistema([Servico de Agendamento<br/>e Processos Automaticos]):::actor

        subgraph Fronteira["Sistema de Moeda Estudantil (Fronteira de Sistema)"]
            direction TB

            subgraph Acesso["Acesso e Identidade"]
                direction LR
                UC01((UC01<br/>Cadastrar aluno)):::usecase
                UC02((UC02<br/>Autenticar por perfil)):::usecase
                UC07((UC07<br/>Cadastrar empresa parceira)):::usecase
            end

            subgraph Reconhecimento["Reconhecimento e Extrato"]
                direction LR
                UC03((UC03<br/>Consultar saldo e extrato)):::usecase
                UC04((UC04<br/>Enviar moedas)):::usecase
                UC05((UC05<br/>Registrar mensagem de reconhecimento)):::automatic
                UC06((UC06<br/>Notificar aluno por email)):::automatic
                UC13((UC13<br/>Creditar moedas semestrais)):::automatic
            end

            subgraph Beneficios["Catalogo e Resgate de Beneficios"]
                direction LR
                UC08((UC08<br/>Gerenciar vantagens)):::usecase
                UC09((UC09<br/>Listar catalogo publico)):::usecase
                UC10((UC10<br/>Resgatar vantagem)):::usecase
                UC11((UC11<br/>Gerar cupom unico)):::automatic
                UC12((UC12<br/>Notificar parceiro por email)):::automatic
            end
        end

        Aluno --> UC01
        Aluno --> UC02
        Aluno --> UC03
        Aluno --> UC09
        Aluno --> UC10

        Professor --> UC02
        Professor --> UC03
        Professor --> UC04

        Parceiro --> UC02
        Parceiro --> UC07
        Parceiro --> UC08

        Sistema --> UC13
        Sistema --> UC06
        Sistema --> UC12

        UC04 -. "<<include>>" .-> UC05
        UC04 -. "<<include>>" .-> UC06
        UC10 -. "<<include>>" .-> UC11
        UC10 -. "<<include>>" .-> UC12
        UC13 -. "<<include>>" .-> UC03

        subgraph Legenda["Legenda de Relacoes UML (Adaptacao Mermaid)"]
            direction TB
            L1["Aresta solida: associacao ator-caso de uso"]:::legend
            L2["Aresta tracejada com <<include>>: comportamento obrigatorio reutilizado"]:::legend
        end
